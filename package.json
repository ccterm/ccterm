{
  "name": "ccterm-terminal",
  "productName": "CCTerm Super Terminal",
  "version": "1.0.0",
  "description": "A modern terminal emulator inspired by Windows Terminal",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "webpack --config webpack.config.ts --mode development",
    "build:prod": "webpack --config webpack.config.ts --mode production",
    "start": "npm run build && electron .",
    "postinstall": "patch-package",
    "lint": "tsc --noEmit",
    "test": "echo \"No tests yet\" && exit 0"
  },
  "keywords": [
    "terminal",
    "electron",
    "xterm"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@lydell/node-pty": "^1.2.0-beta.12",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "express": "^5.2.1",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.20.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "css-loader": "^7.1.4",
    "electron": "^42.0.1",
    "html-webpack-plugin": "^5.6.7",
    "patch-package": "^8.0.1",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0"
  }
}
